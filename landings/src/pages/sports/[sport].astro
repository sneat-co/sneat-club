---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { SPORTS } from "../../data/sports.js";
import { PRODUCTS } from "../../data/products.js";

export function getStaticPaths() {
  return SPORTS.map((s) => ({ params: { sport: s.slug }, props: { sport: s } }));
}

const { sport } = Astro.props;
const others = SPORTS.filter((s) => s.slug !== sport.slug);
const lc = sport.short.toLowerCase();

const title = `${sport.short} club management software — Sneat Club`;
const description = `Free ${lc} club management software: members, ${sport.handles[1].title.toLowerCase()}, schedules, attendance and subs for your ${lc} club — in one place. Sneat Club, part of the Sneat sports platform.`;
---

<BaseLayout title={title} description={description}>
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <p class="kicker">Sneat Club · {sport.name}</p>
      <h1><span class="emoji" aria-hidden="true">{sport.emoji}</span> {sport.tagline}</h1>
      <p class="lede">
        Free <strong>{lc} club management software</strong> from Sneat Club — {sport.intro}
      </p>
      <div class="cta-row">
        <a class="btn btn-primary" href="/#waitlist">Start your club — free</a>
        <a class="btn btn-secondary" href="/app">Try the app preview</a>
      </div>
      <p class="microcopy">🆓 Free to start · 🛡️ Minor-safe · 🔒 Privacy-first</p>
    </div>
  </section>

  <!-- What it handles -->
  <section class="section">
    <div class="container">
      <div class="text-center section-head">
        <p class="eyebrow">Built for {lc} clubs</p>
        <h2>Everything your {lc} club runs on, in one home</h2>
        <p>
          Sneat Club is club management software made for community sport. For a {lc} club that
          means the members, the calendar, the sessions and the subs — handled together, not
          scattered across chats and spreadsheets.
        </p>
      </div>
      <div class="grid grid-4">
        {sport.handles.map((h) => (
          <article class="feature">
            <span class="icon" aria-hidden="true">{h.icon}</span>
            <h3>{h.title}</h3>
            <p>{h.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Plugs into -->
  <section class="section soft">
    <div class="container text-center section-head">
      <p class="eyebrow">One hub, the specialists plugged in</p>
      <h2>Your {lc} club, connected — never rebuilt</h2>
      <p>
        Sneat Club owns your club, teams and members; the rest of the Sneat sports platform does
        the specialist work for your {lc} club:
      </p>
      <ul class="plugs">
        {sport.plugs.map((p) => (
          <li>
            {PRODUCTS[p.name]
              ? <a href={PRODUCTS[p.name]} target="_blank" rel="noopener"><strong>{p.name}</strong></a>
              : <strong>{p.name}</strong>} — {p.text}
          </li>
        ))}
      </ul>
      <p class="microcopy">…and you never re-type a person, a date or a payment twice.</p>
    </div>
  </section>

  <!-- Any sport -->
  <section class="section">
    <div class="container text-center section-head">
      <p class="eyebrow">Not just {lc}</p>
      <h2>Free club management software for any amateur sport</h2>
      <p>
        The same club spine runs every sport. Explore other clubs, or start yours today — {lc}
        or anything else.
      </p>
      <p class="sport-links">
        {others.map((o) => (
          <a href={`/sports/${o.slug}`}>{o.emoji} {o.short}</a>
        ))}
        <a href="/sports/">All sports →</a>
      </p>
      <div class="cta-row center">
        <a class="btn btn-primary" href="/#waitlist">Start your {lc} club — free</a>
        <a class="btn btn-secondary" href="/">Back to Sneat Club</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    background: linear-gradient(160deg, var(--hero-1), var(--hero-2));
    padding-block: var(--space-5);
    text-align: center;
  }
  .kicker { font-weight: 700; font-size: 0.85rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-accent-strong); margin-bottom: var(--space-1); }
  .hero h1 { font-size: clamp(2rem, 5.5vw, 3.1rem); max-width: 18ch; margin-inline: auto; }
  .hero .emoji { font-size: 0.9em; }
  .lede { max-width: 62ch; margin: var(--space-2) auto var(--space-3); font-size: clamp(1.05rem, 2.2vw, 1.25rem); color: var(--color-text-muted); }
  .cta-row { display: flex; flex-wrap: wrap; gap: var(--space-2); justify-content: center; }
  .cta-row.center { margin-top: var(--space-2); }
  .microcopy { margin-top: var(--space-2); font-size: 0.9rem; font-weight: 600; color: var(--color-text-muted); }

  .feature { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius); padding: var(--space-3); box-shadow: var(--shadow); height: 100%; }
  .feature .icon { font-size: 2rem; }
  .feature h3 { font-size: 1.1rem; margin: 0.5rem 0 0.3rem; }
  .feature p { font-size: 0.9rem; margin: 0; }

  .plugs { list-style: none; margin: var(--space-2) auto 0; padding: 0; max-width: 520px; display: grid; gap: 0.5rem; text-align: left; }
  .plugs li { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius); padding: 0.6rem 1rem; box-shadow: var(--shadow); }

  .sport-links { display: flex; flex-wrap: wrap; gap: var(--space-2); justify-content: center; margin-top: var(--space-2); font-weight: 700; }
</style>
