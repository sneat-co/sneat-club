---
const links = [
  { href: "/#how-it-works", label: "How it works" },
  { href: "/#platform", label: "The platform" },
  { href: "/#sports", label: "Your sport" },
  { href: "/#roadmap", label: "Roadmap" },
  { href: "/app", label: "App preview" },
];
---

<header class="site-header">
  <div class="container bar">
    <a href="/" class="brand" aria-label="Sneat Club home"
      >Sneat&nbsp;<span class="mark">Club</span></a
    >
    <nav aria-label="Primary">
      <ul>
        {links.map((l) => (
          <li><a href={l.href}>{l.label}</a></li>
        ))}
      </ul>
    </nav>
    <a href="#waitlist" class="btn signin">Start a club</a>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    background: color-mix(in srgb, var(--color-bg) 88%, transparent);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--color-border);
  }
  .bar { display: flex; align-items: center; gap: var(--space-2); min-height: 64px; }
  .brand { font-weight: 800; font-size: 1.25rem; color: var(--color-text); }
  .brand:hover { text-decoration: none; }
  .mark { color: var(--color-accent); }
  nav { margin-left: auto; }
  nav ul { display: flex; gap: var(--space-3); list-style: none; margin: 0; padding: 0; }
  nav a { color: var(--color-text-muted); font-weight: 600; }
  nav a:hover { color: var(--color-text); text-decoration: none; }
  .signin {
    background: var(--color-text);
    color: #fff;
    padding: 0.5rem 1.1rem;
    font-size: 0.9rem;
  }
  .signin:hover { text-decoration: none; transform: translateY(-2px); }
  @media (max-width: 920px) { nav { display: none; } }
</style>
